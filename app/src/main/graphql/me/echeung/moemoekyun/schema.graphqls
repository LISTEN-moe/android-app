}

type Subscription {
  userFavoriteSong("" id: Int!): SubscriptionSong

  albumNameUpdate("" id: Int!): Album

  albumLinksUpdate("" id: Int!): Album

  albumImageUpdate("" id: Int!): Album

  artistNameUpdate("" id: Int!): Artist

  artistLinksUpdate("" id: Int!): Artist

  artistImageUpdate("" id: Int!): Artist

  sourceNameUpdate("" id: Int!): Source

  sourceDescriptionUpdate("" id: Int!): Source

  sourceLinksUpdate("" id: Int!): Source

  sourceImageUpdate("" id: Int!): Source

  queue("" service: String!): QueueInfoSubscription!

  userQueue("" service: String!, "" uuid: String!): UserQueueInfoSubscription!
}

