}

type UserUploadV2SongSources {
  name: String

  nameRomaji: String
}

type UploadAndCount {
  uploads: [Song!]!

  count: Int!
}

type UserFeed {
  id: Int!

  type: Int!

  content: String

  createdAt: String

  editedAt: String

  song: Song

  upload: UserUpload

  user: User

  author: User

  followTarget: User

