type Query {
  album("" id: Int!): Album

  albums("" offset: Int!, "" count: Int!, "" kpop: Boolean, "" sortByNewest: Boolean): [Album]!

  artist("" id: Int!): Artist

  artists("" offset: Int!, "" count: Int!, "" kpop: Boolean): [Artist]!

  character("" id: Int!): Character

  characters("" offset: Int!, "" count: Int!): [Character]!

  checkFavorite("" songs: [Int!]!): [Int]!

  events("" kpop: Boolean): [Event]!

  news: [News]!

  requests("" kpop: Boolean): [Request]!

  search("" query: ID!, "" favoritesOnly: Boolean, "" kpop: Boolean, "" offset: Int, "" limit: Int): [SongOrFavorite]!

  song("" id: Int!): Song

  songs("" offset: Int, "" count: Int, "" last: Int, "" kpop: Boolean, "" countV2: Int): SongAndCount

  signSong: SignedData!

  queue: Int!

  userQueue: UserQueueInfo!

  source("" id: Int!): Source

  sources("" offset: Int!, "" count: Int!): [Source]!

  user("" username: String!): User

  userUploads("" offset: Int, "" count: Int, "" kpop: Boolean): UserUploadV2AndCount!

  playStatistics("" offset: Int, "" count: Int, "" last: Int, "" kpop: Boolean): PlayStatisticsAndCount
}

"""
The `Int` scalar type represents non-fractional signed whole numeric values. Int can represent values between -(2^31) and 2^31 - 1.
"""
scalar Int

type Album {
  id: Int!

  type: Int!

  name: String!

  nameRomaji: String

  nameSearchRomaji: String

  slug: String

  image: String

  links: [AlbumLinks]

  releaseDate: String!

  jpop: Boolean!

  kpop: Boolean!

  artists: [Artist]!

  characters: [Character]!

  songs: [Song]!
}

"""
The `String` scalar type represents textual data, represented as UTF-8 character sequences. The String type is most often used by GraphQL to represent free-form human-readable text.
"""
scalar String

type AlbumLinks {
  name: String

  url: String
}

"""
The `Boolean` scalar type represents `true` or `false`.
"""
scalar Boolean

type Artist {
  id: Int!

  name: String

  nameRomaji: String

  nameSearchRomaji: String

  slug: String

  links: [ArtistLinks]

  image: String

  lastPlayed: String!

  played: Int!

  jpop: Boolean!

  kpop: Boolean!

  characters: [Character]!

  albums: [Album]!

  songs: SongAndCount!

  songsWithoutAlbum: [Song]!
}

type ArtistLinks {
  name: String

  url: String
}

type Character {
