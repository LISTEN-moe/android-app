}

type Mutation {
  createAlbum("" names: AlbumNameInput!): Album!

  updateAlbumType("" id: Int!, "" type: Int!): Album!

  updateAlbumName("" id: Int!, "" names: AlbumNameInput!): Album!

  updateAlbumReleaseDate("" id: Int!, "" releaseDate: Int!): Album!

  updateAlbumLinks("" id: Int!, "" links: [AlbumLinksInput]!): Album!

  updateAlbumImage("" id: Int!, "" image: Upload!): Album!

  removeAlbum("" id: Int!): Boolean!

  createArtist("" names: ArtistNameInput!): Artist!

  updateArtistName("" id: Int!, "" names: ArtistNameInput!): Artist!

  updateArtistLinks("" id: Int!, "" links: [ArtistLinksInput]!): Artist!

  updateArtistImage("" id: Int!, "" image: Upload!): Artist!

  removeArtist("" id: Int!): Boolean!

  addArtistCharacters("" id: Int!, "" characters: [Int!]!): Artist!

  removeArtistCharacters("" id: Int!, "" characters: [Int!]!): Artist!

  addArtistAlbums("" id: Int!, "" albums: [Int!]!): Artist!

  removeArtistAlbums("" id: Int!, "" albums: [Int!]!): Artist!

  addArtistSongs("" id: Int!, "" songs: [Int!]!): Artist!

  removeArtistSongs("" id: Int!, "" songs: [Int!]!): Artist!

  createCharacter("" names: CharacterNameInput!): Character!

  updateCharacterName("" id: Int!, "" names: CharacterNameInput!): Character!

  updateCharacterDescription("" id: Int!, "" description: String!): Character!

  updateCharacterLinks("" id: Int!, "" links: [CharacterLinksInput]!): Character!

  updateCharacterImage("" id: Int!, "" image: Upload!): Character!

  removeCharacter("" id: Int!): Boolean!

  addCharacterSources("" id: Int!, "" sources: [Int!]!): Character!

  removeCharacterSources("" id: Int!, "" sources: [Int!]!): Character!

  addCharacterAlbums("" id: Int!, "" albums: [Int!]!): Character!

  removeCharacterAlbums("" id: Int!, "" albums: [Int!]!): Character!

  addCharacterSongs("" id: Int!, "" songs: [Int!]!): Character!

  removeCharacterSongs("" id: Int!, "" songs: [Int!]!): Character!

  createEvent("" name: String!, "" description: String, "" presence: String, "" image: String!, "" jpop: Boolean, "" kpop: Boolean): Event!

  publishEvent("" id: Int!, "" kpop: Boolean): Event!

  addEventSongs("" id: Int!, "" songs: [Int!]!): Event!

  removeEventSongs("" id: Int!, "" songs: [Int!]!): Event!

  login("" username: String!, "" password: String!): Login!

  loginMFA("" token: String!): Login!

  register("" email: String!, "" username: String!, "" password: String!): User!

  updateSongTitle("" id: Int!, "" titles: SongTitleInput!): Song!

  updateSongDuration("" id: Int!, "" duration: Int!): Song!

  addSongAlbums("" id: Int!, "" albums: [Int!]!): Song!

  removeSongAlbums("" id: Int!, "" albums: [Int!]!): Song!

  addSongSources("" id: Int!, "" sources: [Int!]!): Song!

  removeSongSources("" id: Int!, "" sources: [Int!]!): Song!

  createSource("" names: SourceNameInput!): Source!

  updateSourceName("" id: Int!, "" names: SourceNameInput!): Source!

  updateSourceDescription("" id: Int!, "" description: String!): Source!

  updateSourceLinks("" id: Int!, "" links: [SourceLinksInput]!): Source!

  updateSourceImage("" id: Int!, "" image: Upload!): Source!

  removeSource("" id: Int!): Boolean!

  addSourceSongs("" id: Int!, "" songs: [Int!]!): Source!

  removeSourceSongs("" id: Int!, "" songs: [Int!]!): Source!

  updateUserAvatar("" avatar: Upload!): User!

  updateUserBanner("" banner: Upload!): User!

  updateUserBiography("" content: String!): User!

  updateUserPassword("" oldPassword: String!, "" newPassword: String!, "" token: String): Login!

  get2FA: QRCode!

  add2FA("" token: String!): MFA!

  remove2FA("" token: String!): MFA!

  createNews("" type: Int!, "" title: String!, "" content: String!): News!

  createUpload("" files: [FileUpload!]!): [UserUploadV2]!

  processUploads("" input: [ProcessUploadsInput!]!): [ProcessUploads]!

  favoriteSong("" id: Int!): Song!

  requestSong("" id: Int!, "" kpop: Boolean): Song!

  requestRandomFavorite("" kpop: Boolean): Song!

  addUserRoles("" username: String!, "" roles: [Int!]!): User!

  removeUserRoles("" username: String!, "" roles: [Int!]!): User!
}

input AlbumNameInput {
  name: String

  nameRomaji: String
}

input AlbumLinksInput {
  name: String

  url: String
}

"""
The `Upload` scalar type represents a file upload.
"""
scalar Upload

input ArtistNameInput {
  name: String

  nameRomaji: String
}

input ArtistLinksInput {
  name: String

  url: String
}

input CharacterNameInput {
  name: String

  nameRomaji: String
