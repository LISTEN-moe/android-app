  nameRomaji: String

  slug: String

  image: String

  description: String

  links: [CharacterLinks]

  artists: [Artist]!

  albums: [Album]!

  songs: [Song]!

  sources: [Source]!
}

type CharacterLinks {
  name: String

  url: String
}

type Song {
  id: Int!

  title: String

  titleRomaji: String

  titleSearchRomaji: String

  slug: String

  duration: Int!

  trackNumber: Int

  group: Boolean!

  snippet: String

  lastPlayed: String!

  played: Int!

  enabled: Boolean!

  jpop: Boolean!

  kpop: Boolean!

  artists: [Artist]!

  characters: [Character]!

  albums: [Album]!

  sources: [Source]!

  uploader: User
}

type Source {
  id: Int!

  name: String

  nameRomaji: String

  slug: String

  image: String

  description: String

  links: [SourceLinks]

  characters: [Character]!

  songs: [Song]!

  songsWithoutAlbum: [Song]!
}

type SourceLinks {
  name: String

  url: String
}

type User {
  uuid: String!

  username: String!

  displayName: String

  avatarImage: String

  bannerImage: String

  bio: String

  roles: [Role]!

  settings: Settings!

  uploadLimit: Int!

  additionalSongRequests: Int!

  favorites("" offset: Int, "" count: Int, "" songId: Int, "" kpop: Boolean): FavoriteAndCount!

  uploads("" offset: Int, "" count: Int): UserUploadAndCount!

  uploadsV2("" offset: Int, "" count: Int, "" processed: Boolean): UserUploadV2AndCount!

  processedUploads("" offset: Int, "" count: Int): UploadAndCount!

  userFeed("" offset: Int, "" count: Int): [UserFeed]!

  systemFeed("" offset: Int, "" count: Int): [SystemFeed]!

  requests: RequestsAndCount!
}

type Role {
  id: ID!

  name: String!

  slug: String!

  color: String

  songRequests: Int!

  enabled: Boolean!
}

"""
The `ID` scalar type represents a unique identifier, often used to refetch an object or as key for a cache. The ID type appears in a JSON response as a String; however, it is not intended to be human-readable. When expected as an input type, any string (such as `"4"`) or integer (such as `4`) input value will be accepted as an ID.
"""
scalar ID

type Settings {
  mfa: Boolean

  mfaSecret: String

  mfaOtp: String

  mfaCreatedAt: String
}

